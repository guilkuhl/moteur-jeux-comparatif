{
  "name": "pixel-lab-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:size": "node scripts/check-size.mjs"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "pinia": "^2.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^10.9.0",
    "happy-dom": "^13.0.0",
    "prettier": "^3.2.0",
    "typescript": "^6.0.3",
    "vite": "^5.1.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.0.0"
  }
}
